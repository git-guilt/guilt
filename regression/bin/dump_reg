#!/bin/sh

if [ $# -ne 1 ]; then
	echo "ERROR" >&2
	exit 1
fi

UNAME_S=`uname -s`

if [ -r "$REG_DIR/../os.$UNAME_S" ]; then
	. "$REG_DIR/../os.$UNAME_S"
else
	echo "Unsupported operating system: $UNAME_S" >&2
	exit 1
fi

if [ -d "$1" ]; then
	echo "d $1"
elif [ -f "$1" ]; then
	echo "f `sha1 "$1"`"
else
	echo "? $1"
fi
